{
  "name": "rp-soundboard-ultimate",
  "version": "0.2.0",
  "private": true,
  "description": "Native TeamSpeak 3 soundboard plugin for Windows.",
  "scripts": {
    "test": "node --test tests/release.test.js",
    "validate:release": "node scripts/validate-release.js",
    "deploy:ts3": "powershell -ExecutionPolicy Bypass -File scripts/test-teamspeak.ps1 -Build -StopTeamSpeak",
    "deploy:ts3:start": "powershell -ExecutionPolicy Bypass -File scripts/test-teamspeak.ps1 -Build -StopTeamSpeak -StartTeamSpeak"
  },
  "author": "fALECX",
  "license": "MIT",
  "keywords": [
    "ts3",
    "teamspeak",
    "soundboard",
    "plugin",
    "windows"
  ]
}
